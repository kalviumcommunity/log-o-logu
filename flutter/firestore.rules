rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helper Functions ────────────────────────────────────────────────────

    // Returns the calling user's role from their profile document in Firestore.
    // Note: This costs an extra read if not already cached.
    function role() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Shorthand role checks.
    function isAdmin()    { return role() == 'admin'; }
    function isGuard()    { return role() == 'guard'; }
    function isResident() { return role() == 'resident'; }

    // True when the document belongs to the signed-in user.
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ─── /users ──────────────────────────────────────────────────────────────
    match /users/{userId} {
      // Allow reading specific profiles.
      allow get: if isOwner(userId) || isAdmin();
      
      // Allow listing for admin and guard (resident directory).
      allow list: if request.auth != null && (isAdmin() || isGuard());

      // Registration: users can create only their own profile.
      allow create: if isOwner(userId)
                    && (
                      request.resource.data.role == 'admin'
                      || (
                        request.resource.data.role == 'guard'
                        && request.resource.data.isApproved == false
                        && request.resource.data.phone is string
                        && request.resource.data.phone.size() > 0
                      )
                      || (
                        request.resource.data.role == 'resident'
                        && request.resource.data.isApproved == false
                        && request.resource.data.phone is string
                        && request.resource.data.phone.size() > 0
                        && request.resource.data.flatNumber is string
                        && request.resource.data.flatNumber.size() > 0
                        && request.resource.data.buildingName is string
                        && request.resource.data.buildingName.size() > 0
                      )
                    );

      // Users can update only their own basic profile details, not approval.
      allow update: if (isOwner(userId)
                    && request.resource.data.isApproved == resource.data.isApproved)
                    || isAdmin();

      allow delete: if isAdmin();
    }

    // ─── /apartments ─────────────────────────────────────────────────────────
    match /apartments/{apartmentId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ─── /invites ────────────────────────────────────────────────────────────
    match /invites/{inviteId} {
      // Allow listing all for seeding script check.
      allow list: if request.auth != null;

      allow get: if (isResident() && resource.data.residentUid == request.auth.uid)
                    || isGuard()
                    || isAdmin();

      allow create: if isOwner(request.resource.data.residentUid)
                    || isAdmin();

      allow update: if (isOwner(resource.data.residentUid))
                    || isGuard()
                    || isAdmin();

      allow delete: if isOwner(resource.data.residentUid)
                    || isAdmin();
    }

    // ─── /logs ───────────────────────────────────────────────────────────────
    match /logs/{logId} {
      allow read:   if isGuard()
                    || (isResident() && resource.data.residentUid == request.auth.uid)
                    || isAdmin();

      allow create: if isGuard()
                    && request.resource.data.scannedByGuardUid == request.auth.uid;

      allow update: if isGuard()
                    || isAdmin();

      allow delete: if isAdmin();
    }
  }
}
